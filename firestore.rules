rules_version = '2';

// Polla Mundialista security rules — the integrity backbone.
//
// TWO-WRITERS RULE (constitution §3):
//   - matches / standings / config are GLOBAL and written ONLY by the ingestion
//     service account (admin SDK, which bypasses these rules). Clients are read-only.
//   - per-group leaderboards (groups/{gid}/leaderboard) are likewise admin-SDK-only.
//   - the browser writes ONLY the signed-in user's own prediction, in a group they
//     belong to, and ONLY before kickoff.
//   - ORPHAN CLEANUP amendment (2026-06-11, constitution §3 carve-out): a group ADMIN
//     may additionally DELETE (never create/update) prediction docs whose author is NO
//     LONGER a participant of the group (member-removal cleanup); deleting a nonexistent
//     prediction is a permitted no-op. See the predictions delete rule.
//
// AUTHORITATIVE KICKOFF LOCK (constitution §4, AMENDED by ticket 019):
//   prediction create/update is allowed only while `request.time < match.kickoff − 10min`,
//   using SERVER time and the GLOBAL matches/{matchId} doc. A uniform 10-minute pre-kickoff
//   buffer applies in BOTH prediction modes. The client clock is never trusted.
//
//   PREDICTION MODES (ticket 019): each group has a `mode` (absent ⇒ 'lazy').
//     - LAZY (or mode-less): a prediction locks per match at `match.kickoff − 10min`.
//     - STRICT: predictions lock in two batch windows read from the GLOBAL config/tournament:
//         * GROUP_STAGE predictions all lock at `firstCupMatchKickoff − 10min`;
//         * knockout predictions (LAST_32 … FINAL) all lock at `firstKnockoutKickoff − 10min`,
//           independent of each match's own kickoff.
//   The group `mode` is admin-writable but FROZEN once `request.time ≥ firstCupMatchKickoff − 10min`.
//
// MULTI-TENANT / GROUP MODEL (ticket 012):
//   Membership, predictions, and leaderboards are PER GROUP, under groups/{gid}.
//   App access is OPEN: any signed-in Google user may read group metadata and create a
//   group. Gating is per-group.
//
//   OWNER-DERIVED MEMBERSHIP: the group owner is recorded ONLY by groups/{gid}.ownerUid —
//   there is NO members/{owner} doc. Creating a group is a SINGLE doc write (no batch,
//   no self-member-create). Member docs exist only for JOINERS (pending -> approved).
//     isOwner(gid)       = groups/{gid}.ownerUid == auth.uid
//     isGroupMember(gid) = isOwner(gid) || (member doc exists && status == 'approved')
//     isGroupAdmin(gid)  = isOwner(gid) || (member doc exists && role == 'admin'
//                                            && status == 'approved')
//
// COST NOTE: group lookups add get()s. A prediction create/update performs:
//   1 get() on the GLOBAL match doc (kickoff lock) + isGroupMember(gid) which does
//   1 get() on groups/{gid} (ownerUid) and, only if not owner, 1 get()/exists() on
//   groups/{gid}/members/{uid} — so ~2-3 extra reads. Member-doc admin writes do
//   isGroupAdmin(gid) = up to 2 get()s (group doc + member doc). Reads of global public
//   collections add no get()s. Acceptable at this scale (a few dozen members/group).
service cloud.firestore {
  match /databases/{database}/documents {

    // ---- generic helpers ----------------------------------------------------

    function isSignedIn() {
      return request.auth != null;
    }

    function isInt0to30(v) {
      return v is int && v >= 0 && v <= 30;
    }

    // ---- group membership helpers (owner-derived) ---------------------------

    function groupData(gid) {
      return get(/databases/$(database)/documents/groups/$(gid)).data;
    }

    // The group owner is implicit (no member doc). One get() on the group doc.
    function isOwner(gid) {
      return isSignedIn()
        && exists(/databases/$(database)/documents/groups/$(gid))
        && groupData(gid).ownerUid == request.auth.uid;
    }

    function memberDocExists(gid) {
      return exists(/databases/$(database)/documents/groups/$(gid)/members/$(request.auth.uid));
    }

    function memberDocData(gid) {
      return get(/databases/$(database)/documents/groups/$(gid)/members/$(request.auth.uid)).data;
    }

    // Owner OR an approved member doc. Up to 2 get()s (group doc, then member doc).
    function isGroupMember(gid) {
      return isOwner(gid)
        || (isSignedIn() && memberDocExists(gid) && memberDocData(gid).status == 'approved');
    }

    // Owner OR an approved member doc with role == 'admin'.
    function isGroupAdmin(gid) {
      return isOwner(gid)
        || (
          isSignedIn()
          && memberDocExists(gid)
          && memberDocData(gid).status == 'approved'
          && memberDocData(gid).role == 'admin'
        );
    }

    // True iff `uid` is still a participant of group `gid`: the implicit owner, or ANY
    // member doc (any status — pending/rejected joiners are protected from cleanup too).
    // COST: 1 get() on groups/{gid} (de-duped with isOwner/isGroupAdmin within the same
    // evaluation) + 1 exists() on groups/{gid}/members/{uid}.
    function isParticipant(gid, uid) {
      return groupData(gid).ownerUid == uid
        || exists(/databases/$(database)/documents/groups/$(gid)/members/$(uid));
    }

    // ---- superadmin (app-level god-view; ticket 014) ------------------------
    // App-level superadmin = users/{uid}.isAdmin == true. This flag is settable ONLY
    // via the admin SDK (the `users` rules forbid any client setting/changing it), so
    // no user can self-promote. It is SEPARATE from per-group admin (isGroupAdmin).
    //
    // Used only as a FINAL OR on READ rules for members / leaderboard / predictions, so
    // normal members/owners short-circuit before this helper runs and never pay its cost.
    // COST: 1 get() on users/{uid} (plus the implicit exists()). Evaluated last, only
    // when the caller is NOT already an owner/member, so member/owner reads add no extra
    // read. Read-only oversight — no create/update/delete rule references this.
    function isSuperAdmin() {
      return isSignedIn()
        && exists(/databases/$(database)/documents/users/$(request.auth.uid))
        && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.isAdmin == true;
    }

    // ---- global, read-only collections (admin SDK writes only) --------------

    match /matches/{matchId} {
      allow read: if isSignedIn();
      allow write: if false;
    }

    match /standings/{groupId} {
      allow read: if isSignedIn();
      allow write: if false;
    }

    match /config/{docId} {
      allow read: if isSignedIn();
      allow write: if false;
    }

    // ---- users (global profiles) --------------------------------------------
    // Owner reads/creates/updates their own profile. `isAdmin` may never be set or
    // changed by a client. (Note: app-level admin is deprecated by ticket 012 — admin
    // is now per-group — but the field is still guarded against tampering.)

    match /users/{uid} {
      allow read: if isSignedIn() && request.auth.uid == uid;

      allow create: if isSignedIn()
        && request.auth.uid == uid
        && request.resource.data.uid == uid
        && (!('isAdmin' in request.resource.data.keys()) || request.resource.data.isAdmin == false);

      allow update: if isSignedIn()
        && request.auth.uid == uid
        && request.resource.data.uid == uid
        && (
          !('isAdmin' in request.resource.data.keys())
          || request.resource.data.isAdmin == resource.data.isAdmin
        );

      allow delete: if false;
    }

    // ---- serverTime ---------------------------------------------------------
    // Throwaway per-user doc used by useServerTime to measure the client/server clock
    // offset. Owner-only; carries no sensitive data.

    match /serverTime/{uid} {
      allow read, write: if isSignedIn() && request.auth.uid == uid;
    }

    // ---- members collection-group read --------------------------------------
    // Authorizes `collectionGroup('members').where('uid','==', myUid)` (useMyGroups:
    // "the groups I've joined"). Collection-group queries are authorized by a recursive
    // match analyzed against the query's FIELD filter — a nested per-group match + a
    // doc-id rule do NOT cover them. Read-only here, scoped to the caller's own member
    // docs (`resource.data.uid == request.auth.uid`); writes stay governed by the nested
    // groups/{gid}/members rule. No security widening (you can already read your own doc).
    match /{path=**}/members/{memberUid} {
      allow read: if isSignedIn() && resource.data.uid == request.auth.uid;
    }

    // ---- groups -------------------------------------------------------------
    // Open app access: any signed-in user may read group metadata (needed for the join
    // page) and create a group they own. Group metadata isn't sensitive (knowing a gid
    // only lets you *request* to join). Owner-only update/delete.

    match /groups/{gid} {
      allow read: if isSignedIn();

      // Create: signed-in user creates a group with themselves as owner (single write).
      allow create: if isSignedIn()
        && request.resource.data.ownerUid == request.auth.uid;

      // Owner may update group fields, but `mode` and `scoring` are GATED (ticket 019/025):
      //   - a `mode` change is allowed only before the freeze (modeChangeable());
      //   - a `scoring` change is allowed only before the freeze AND only with a valid shape
      //     (validScoring) — closing the old "owner may write any non-mode field freely"
      //     loophole so `scoring` is validated + frozen, not free.
      // A non-owner GROUP ADMIN may change ONLY `mode` and/or `scoring` (nothing else), and
      // only before the freeze; a `scoring` change must also be a valid shape. Any mode/scoring
      // change is denied at/after firstCupMatchKickoff − 10min (immutability, ticket 019/025).
      allow update: if
        (
          isOwner(gid)
          && (!modeChanged() || modeChangeable())
          && (!scoringChanged() || (modeChangeable() && validScoring(request.resource.data.scoring)))
        )
        || (
          !isOwner(gid) && isGroupAdmin(gid)
          && onlyModeOrScoringChanged()
          && (modeChanged() || scoringChanged())
          && modeChangeable()
          && (!scoringChanged() || validScoring(request.resource.data.scoring))
        );
      allow delete: if isOwner(gid);

      // ---- groups/{gid}/members ---------------------------------------------
      // Joiners only (the owner is implicit via groups/{gid}.ownerUid).
      //   - create: signed-in user self-requests their OWN doc as role 'member',
      //     status 'pending', no decision stamped. They may NOT self-approve nor
      //     grant themselves 'admin'.
      //   - update: (a) owner re-request after rejection (rejected -> pending, own doc,
      //     no decision stamped); or (b) a GROUP ADMIN deciding (sets status, stamps
      //     decidedBy == auth.uid and decidedAt != null, may set role). A non-admin can
      //     NEVER reach 'approved' or 'admin'.
      //   - read: own doc OR a group member (so group admins / members can see the roster).
      //   - delete: group admin only.

      match /members/{uid} {
        // Single-doc reads: own doc (by id, incl. a non-existent one — GroupProvider) or
        // a group member/admin reading the roster. The collectionGroup(members) query in
        // useMyGroups is authorized separately by the recursive-wildcard rule below.
        allow read: if (isSignedIn()
          && (request.auth.uid == uid || isGroupMember(gid)))
          || isSuperAdmin();

        // Self-request to join: own doc, uid matches, role 'member', pending, no decision.
        allow create: if isSignedIn()
          && request.auth.uid == uid
          && request.resource.data.uid == uid
          && request.resource.data.role == 'member'
          && request.resource.data.status == 'pending'
          && (
            !('decidedBy' in request.resource.data.keys())
            || request.resource.data.decidedBy == null
          )
          && (
            !('decidedAt' in request.resource.data.keys())
            || request.resource.data.decidedAt == null
          );

        allow update: if isSignedIn() && (
          // (a) owner re-requesting after a rejection: rejected -> pending only.
          (
            request.auth.uid == uid
            && resource.data.status == 'rejected'
            && request.resource.data.status == 'pending'
            && request.resource.data.uid == uid
            && (
              !('decidedBy' in request.resource.data.keys())
              || request.resource.data.decidedBy == null
            )
            && (
              !('decidedAt' in request.resource.data.keys())
              || request.resource.data.decidedAt == null
            )
          )
          // (b) a group admin deciding: stamps themselves as the decider.
          || (
            isGroupAdmin(gid)
            && request.resource.data.uid == resource.data.uid
            && request.resource.data.decidedBy == request.auth.uid
            && request.resource.data.decidedAt != null
          )
        );

        allow delete: if isGroupAdmin(gid);
      }

      // ---- groups/{gid}/predictions -----------------------------------------
      // Doc id is `{uid}_{matchId}`. Owner-only write. Kickoff-locked against the
      // GLOBAL matches/{matchId} doc. No points/breakdown tampering. Group members only.
      // Orphan cleanup (2026-06-11): admins may DELETE (never create/update) predictions
      // of NON-participants; deleting a nonexistent prediction is a permitted no-op.

      match /predictions/{predId} {
        // Reveal-at-kickoff (ticket 013): a group member reads their OWN prediction
        // anytime, or ANOTHER member's prediction only once that match has kicked off
        // (server time >= the GLOBAL matches/{matchId}.kickoff). Pre-kickoff, others'
        // predictions stay hidden so no one can copy. Cost: reading another member's
        // prediction adds 1 exists()+1 get() on the global match doc (matchHasKickedOff)
        // on top of isGroupMember(gid)'s lookups — acceptable at group scale.
        allow read: if (isSignedIn()
          && isGroupMember(gid)
          && (
            resource.data.uid == request.auth.uid
            || matchHasKickedOff(resource.data.matchId)
          ))
          || isSuperAdmin();

        allow create: if isGroupMember(gid)
          && request.auth.uid == request.resource.data.uid
          && predId == request.auth.uid + '_' + request.resource.data.matchId
          && predictionShapeValid()
          && predictionWindowOpen(gid, request.resource.data.matchId);

        allow update: if isGroupMember(gid)
          && request.auth.uid == request.resource.data.uid
          && predId == request.auth.uid + '_' + request.resource.data.matchId
          && request.resource.data.matchId == resource.data.matchId
          && predictionShapeValid()
          && predictionWindowOpen(gid, request.resource.data.matchId);

        // ORPHAN CLEANUP (amendment 2026-06-11, constitution §3 carve-out): when an
        // admin removes a member, the admin's browser also deletes that ex-member's
        // prediction docs. A group ADMIN may DELETE a prediction ONLY when its author
        // is NO LONGER a participant: not the implicit owner AND no member doc of ANY
        // status (pending/rejected joiners stay protected). `resource == null` (the doc
        // doesn't exist) is a permitted no-op so the client can blind-delete
        // `{uid}_{matchId}` for every match WITHOUT any new read access — the
        // reveal-at-kickoff READ rule above is untouched. Participants (including the
        // author themselves) still can NEVER delete a live prediction.
        // COST: isGroupAdmin(gid) ≤2 get()s; an existing doc adds 1 exists() on the
        // author's member doc (the group-doc get() is de-duped) — ~3 lookups worst case.
        allow delete: if isGroupAdmin(gid)
          && (resource == null || !isParticipant(gid, resource.data.uid));
      }

      // ---- groups/{gid}/leaderboard -----------------------------------------
      // Per-group aggregate. Group members read; admin SDK is the only writer.

      match /leaderboard/{uid} {
        allow read: if isGroupMember(gid) || isSuperAdmin();
        allow write: if false;
      }
    }

    // ---- prediction validation helpers (global; reference GLOBAL matches) ---

    function predictionShapeValid() {
      return request.resource.data.uid is string
        && request.resource.data.matchId is string
        && isInt0to30(request.resource.data.homeGoals)
        && isInt0to30(request.resource.data.awayGoals)
        // clients may never write graded fields.
        && !('points' in request.resource.data.keys())
        && !('breakdown' in request.resource.data.keys());
    }

    function matchKickoff(matchId) {
      return get(/databases/$(database)/documents/matches/$(matchId)).data.kickoff;
    }

    // True once the referenced GLOBAL match exists and HAS kicked off (server time).
    // Backs the reveal-at-kickoff read on group predictions (ticket 013). 1 exists()
    // + 1 get() on the global match doc.
    function matchHasKickedOff(matchId) {
      return exists(/databases/$(database)/documents/matches/$(matchId))
        && request.time >= matchKickoff(matchId);
    }

    // ---- prediction-mode helpers (ticket 019) -------------------------------
    // All time comparisons use SERVER request.time against the GLOBAL match doc /
    // GLOBAL config/tournament, with a uniform 10-minute pre-kickoff buffer.
    //
    // COST: the LAZY branch reads only the group doc (cached via isGroupMember) and the
    // match doc (cached via beforeKickoff). The STRICT branch additionally reads the GLOBAL
    // config/tournament doc (1 get()) and the match doc's `stage` (same doc, cached). All
    // get()s for the same path within one evaluation are de-duped, so a strict prediction
    // write touches ~3 distinct docs (group, match, config/tournament) — within budget.

    // GLOBAL config/tournament: the two batch-window cutoffs the strict mode needs.
    function tournamentCfg() {
      return get(/databases/$(database)/documents/config/tournament).data;
    }

    // The stage of the referenced GLOBAL match ('GROUP_STAGE', 'LAST_32', … 'FINAL').
    function matchStage(matchId) {
      return get(/databases/$(database)/documents/matches/$(matchId)).data.stage;
    }

    // The group's prediction mode; absent ⇒ 'lazy' (back-compat, no backfill).
    function groupMode(gid) {
      return groupData(gid).get('mode', 'lazy');
    }

    // STRICT: a GROUP_STAGE prediction locks at firstCupMatchKickoff − 10min; any other
    // (knockout) stage locks at firstKnockoutKickoff − 10min — independent of the match's
    // own kickoff.
    function strictWindowOpen(matchId) {
      return matchStage(matchId) == 'GROUP_STAGE'
        ? request.time < tournamentCfg().firstCupMatchKickoff - duration.value(10, 'm')
        : request.time < tournamentCfg().firstKnockoutKickoff - duration.value(10, 'm');
    }

    // True while a prediction for `matchId` may be written under group `gid`'s mode.
    // The GLOBAL match must exist; strict reads config/tournament, lazy uses match.kickoff.
    function predictionWindowOpen(gid, matchId) {
      return exists(/databases/$(database)/documents/matches/$(matchId))
        && (groupMode(gid) == 'strict'
            ? strictWindowOpen(matchId)
            : request.time < matchKickoff(matchId) - duration.value(10, 'm'));
    }

    // ---- group-mode write gating (ticket 019) -------------------------------
    // True iff this update changes the group's `mode` (absent treated as 'lazy').
    function modeChanged() {
      return resource.data.get('mode', 'lazy') != request.resource.data.get('mode', 'lazy');
    }

    // The freeze instant: a mode change is allowed only before firstCupMatchKickoff − 10min.
    // If config/tournament isn't seeded yet, the tournament isn't configured (necessarily
    // before the first match) so changing mode stays open — setup can't be bricked.
    function modeChangeable() {
      return !exists(/databases/$(database)/documents/config/tournament)
        || request.time < tournamentCfg().firstCupMatchKickoff - duration.value(10, 'm');
    }

    // ---- group-scoring write gating (ticket 025) ----------------------------
    // The per-group `scoring` config (mirrors `mode`): an admin-managed group setting,
    // editable until the SAME freeze instant as `mode` (modeChangeable() =
    // firstCupMatchKickoff − 10min) and frozen thereafter. The admin editor always writes
    // the COMPLETE object, so the rule validates one fixed shape. No new get(): both the
    // freeze (modeChangeable, via tournamentCfg) and the diff/shape checks reuse docs the
    // group update already loads — no extra read beyond what `mode` gating already paid.

    // True iff this update changes the group's `scoring` field (absent treated as null).
    // Any difference (added, removed, or mutated) counts. Cheap: a single map compare.
    function scoringChanged() {
      return resource.data.get('scoring', null) != request.resource.data.get('scoring', null);
    }

    // True iff `s` is a well-formed scoring config: exactly the expected top-level keys,
    // base tiers (exact/outcome/goalDiffBonus) non-negative integers, a bool gating flag,
    // gradeOn pinned to 'fullTime90', and a roundBonus map with EXACTLY the 7 stage keys,
    // each a non-negative integer. `is int` rejects floats (e.g. 1.5).
    function validScoringRoundBonus(rb) {
      return rb is map
        && rb.keys().hasOnly(['GROUP_STAGE', 'LAST_32', 'LAST_16', 'QUARTER_FINALS', 'SEMI_FINALS', 'FINAL', 'THIRD_PLACE'])
        && rb.keys().hasAll(['GROUP_STAGE', 'LAST_32', 'LAST_16', 'QUARTER_FINALS', 'SEMI_FINALS', 'FINAL', 'THIRD_PLACE'])
        && rb.GROUP_STAGE is int && rb.GROUP_STAGE >= 0
        && rb.LAST_32 is int && rb.LAST_32 >= 0
        && rb.LAST_16 is int && rb.LAST_16 >= 0
        && rb.QUARTER_FINALS is int && rb.QUARTER_FINALS >= 0
        && rb.SEMI_FINALS is int && rb.SEMI_FINALS >= 0
        && rb.FINAL is int && rb.FINAL >= 0
        && rb.THIRD_PLACE is int && rb.THIRD_PLACE >= 0;
    }

    function validScoring(s) {
      return s is map
        && s.keys().hasOnly(['exact', 'outcome', 'goalDiffBonus', 'goalDiffOnlyOnCorrectOutcome', 'gradeOn', 'roundBonus'])
        && s.keys().hasAll(['exact', 'outcome', 'goalDiffBonus', 'goalDiffOnlyOnCorrectOutcome', 'gradeOn', 'roundBonus'])
        && s.exact is int && s.exact >= 0
        && s.outcome is int && s.outcome >= 0
        && s.goalDiffBonus is int && s.goalDiffBonus >= 0
        && s.goalDiffOnlyOnCorrectOutcome is bool
        && s.gradeOn == 'fullTime90'
        && validScoringRoundBonus(s.roundBonus);
    }

    // True iff this update touches ONLY `mode` and/or `scoring` (confines non-owner admins).
    function onlyModeOrScoringChanged() {
      return request.resource.data.diff(resource.data).affectedKeys().hasOnly(['mode', 'scoring']);
    }
  }
}
