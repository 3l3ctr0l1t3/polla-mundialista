rules_version = '2';

// Polla Mundialista security rules — the integrity backbone (ticket 003).
//
// TWO-WRITERS RULE (constitution §3):
//   - matches / leaderboard / standings / config are written ONLY by the ingestion
//     service account (admin SDK, which bypasses these rules). Clients are read-only.
//   - the browser writes ONLY the signed-in user's own prediction, and ONLY before kickoff.
//
// AUTHORITATIVE KICKOFF LOCK (constitution §4):
//   prediction create/update is allowed only while `request.time < match.kickoff`,
//   using SERVER time. The client clock is never trusted.
//
// MEMBERSHIP MODEL (ticket 011):
//   membership is the `members/{uid}` request->approve model, NOT the old
//   `config/allowlist`. A user creates their own `members/{uid}` with status
//   'pending'; only an admin may change status. `config/allowlist` is DEPRECATED
//   and no longer consulted by these rules (it remains readable for legacy reads).
//
// COST NOTE: each prediction create/update performs ONE get() on the target match doc
//   (the kickoff lock) plus membership get()s: isAdmin() does one get() on users/{uid},
//   and (only if not admin) isApprovedMember() does one get() on members/{uid}. So a
//   prediction write does ~2-3 extra reads. members/{uid} admin writes additionally
//   get() users/{uid} via isAdmin(). Acceptable at this scale (a few dozen participants
//   x 104 matches). Reads of public collections add no get()s.
service cloud.firestore {
  match /databases/{database}/documents {

    // ---- helpers ------------------------------------------------------------

    function isSignedIn() {
      return request.auth != null;
    }

    // True if the signed-in user's users/{uid} doc has isAdmin == true. One get().
    function isAdmin() {
      return isSignedIn()
        && exists(/databases/$(database)/documents/users/$(request.auth.uid))
        && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.isAdmin == true;
    }

    // True if the signed-in user has an approved members/{uid} request. One get().
    function isApprovedMember() {
      return isSignedIn()
        && exists(/databases/$(database)/documents/members/$(request.auth.uid))
        && get(/databases/$(database)/documents/members/$(request.auth.uid)).data.status == 'approved';
    }

    // Membership gate for predictions (ticket 011): an admin, or an approved member.
    // Replaces the deprecated config/allowlist lookup. Admins are always members.
    function isMember() {
      return isAdmin() || isApprovedMember();
    }

    function matchKickoff(matchId) {
      return get(/databases/$(database)/documents/matches/$(matchId)).data.kickoff;
    }

    // True while the referenced match exists and has not kicked off (server time).
    function beforeKickoff(matchId) {
      return exists(/databases/$(database)/documents/matches/$(matchId))
        && request.time < matchKickoff(matchId);
    }

    function isInt0to30(v) {
      return v is int && v >= 0 && v <= 30;
    }

    // ---- public, read-only collections (admin SDK writes only) --------------

    match /matches/{matchId} {
      allow read: if isSignedIn();
      allow write: if false;
    }

    match /leaderboard/{uid} {
      allow read: if isSignedIn();
      allow write: if false;
    }

    match /standings/{groupId} {
      allow read: if isSignedIn();
      allow write: if false;
    }

    match /config/{docId} {
      allow read: if isSignedIn();
      allow write: if false;
    }

    // ---- users --------------------------------------------------------------
    // Owner reads/creates/updates their own profile. `isAdmin` may never be set or
    // changed by a client (admin flag is granted out-of-band via the admin SDK).

    match /users/{uid} {
      allow read: if isSignedIn() && request.auth.uid == uid;

      allow create: if isSignedIn()
        && request.auth.uid == uid
        && request.resource.data.uid == uid
        && (!('isAdmin' in request.resource.data.keys()) || request.resource.data.isAdmin == false);

      allow update: if isSignedIn()
        && request.auth.uid == uid
        && request.resource.data.uid == uid
        // isAdmin must be absent or unchanged from its stored value.
        && (
          !('isAdmin' in request.resource.data.keys())
          || request.resource.data.isAdmin == resource.data.isAdmin
        );

      allow delete: if false;
    }

    // ---- members ------------------------------------------------------------
    // Self-enrollment + admin approval (ticket 011). Doc id is the user's uid.
    //   - create: a signed-in user requests to join their OWN doc as 'pending';
    //     they may NOT set decidedBy/decidedAt and may NOT self-approve.
    //   - update: the owner may ONLY re-request after a rejection (rejected ->
    //     pending, no decided* fields); an admin may set any status and stamps
    //     decidedBy == their uid + decidedAt. A non-admin can never reach 'approved'.
    //   - read: owner or admin.
    //   - delete: admin only.

    function memberDecidedFieldsAbsentOrNull() {
      return (
        !('decidedBy' in request.resource.data.keys())
        || request.resource.data.decidedBy == null
      ) && (
        !('decidedAt' in request.resource.data.keys())
        || request.resource.data.decidedAt == null
      );
    }

    match /members/{uid} {
      allow read: if isSignedIn()
        && (request.auth.uid == uid || isAdmin());

      // Self-request to join: own doc, uid matches, starts pending, no decision stamped.
      allow create: if isSignedIn()
        && request.auth.uid == uid
        && request.resource.data.uid == uid
        && request.resource.data.status == 'pending'
        && memberDecidedFieldsAbsentOrNull();

      allow update: if isSignedIn() && (
        // (a) owner re-requesting after a rejection: rejected -> pending only.
        (
          request.auth.uid == uid
          && resource.data.status == 'rejected'
          && request.resource.data.status == 'pending'
          && request.resource.data.uid == uid
          && memberDecidedFieldsAbsentOrNull()
        )
        // (b) an admin deciding: any status, stamping themselves as the decider.
        || (
          isAdmin()
          && request.resource.data.uid == resource.data.uid
          && request.resource.data.decidedBy == request.auth.uid
          && request.resource.data.decidedAt != null
        )
      );

      allow delete: if isAdmin();
    }

    // ---- serverTime ---------------------------------------------------------
    // Throwaway per-user doc used by useServerTime to measure the client/server
    // clock offset (write serverTimestamp(), read it back). Owner-only; carries no
    // sensitive data. Makes the kickoff-lock countdown immune to a wrong device clock.

    match /serverTime/{uid} {
      allow read, write: if isSignedIn() && request.auth.uid == uid;
    }

    // ---- predictions --------------------------------------------------------
    // Doc id is `{uid}_{matchId}`. Owner-only. Kickoff-locked. No points/breakdown
    // tampering. Members only.

    function predictionShapeValid() {
      return request.resource.data.uid is string
        && request.resource.data.matchId is string
        && isInt0to30(request.resource.data.homeGoals)
        && isInt0to30(request.resource.data.awayGoals)
        // clients may never write graded fields.
        && !('points' in request.resource.data.keys())
        && !('breakdown' in request.resource.data.keys());
    }

    function ownsPrediction(predId) {
      return request.auth.uid == request.resource.data.uid
        // doc id must be exactly `{uid}_{matchId}`.
        && predId == request.auth.uid + '_' + request.resource.data.matchId;
    }

    match /predictions/{predId} {
      allow read: if isSignedIn()
        && resource.data.uid == request.auth.uid;

      allow create: if isMember()
        && ownsPrediction(predId)
        && predictionShapeValid()
        && beforeKickoff(request.resource.data.matchId);

      allow update: if isMember()
        && ownsPrediction(predId)
        // matchId is immutable across an update.
        && request.resource.data.matchId == resource.data.matchId
        && predictionShapeValid()
        && beforeKickoff(request.resource.data.matchId);

      allow delete: if false;
    }
  }
}
