rules_version = '2';

// Polla Mundialista security rules — the integrity backbone.
//
// TWO-WRITERS RULE (constitution §3):
//   - matches / standings / config are GLOBAL and written ONLY by the ingestion
//     service account (admin SDK, which bypasses these rules). Clients are read-only.
//   - per-group leaderboards (groups/{gid}/leaderboard) are likewise admin-SDK-only.
//   - the browser writes ONLY the signed-in user's own prediction, in a group they
//     belong to, and ONLY before kickoff.
//
// AUTHORITATIVE KICKOFF LOCK (constitution §4):
//   prediction create/update is allowed only while `request.time < match.kickoff`,
//   using SERVER time and the GLOBAL matches/{matchId} doc. The client clock is never
//   trusted.
//
// MULTI-TENANT / GROUP MODEL (ticket 012):
//   Membership, predictions, and leaderboards are PER GROUP, under groups/{gid}.
//   App access is OPEN: any signed-in Google user may read group metadata and create a
//   group. Gating is per-group.
//
//   OWNER-DERIVED MEMBERSHIP: the group owner is recorded ONLY by groups/{gid}.ownerUid —
//   there is NO members/{owner} doc. Creating a group is a SINGLE doc write (no batch,
//   no self-member-create). Member docs exist only for JOINERS (pending -> approved).
//     isOwner(gid)       = groups/{gid}.ownerUid == auth.uid
//     isGroupMember(gid) = isOwner(gid) || (member doc exists && status == 'approved')
//     isGroupAdmin(gid)  = isOwner(gid) || (member doc exists && role == 'admin'
//                                            && status == 'approved')
//
// COST NOTE: group lookups add get()s. A prediction create/update performs:
//   1 get() on the GLOBAL match doc (kickoff lock) + isGroupMember(gid) which does
//   1 get() on groups/{gid} (ownerUid) and, only if not owner, 1 get()/exists() on
//   groups/{gid}/members/{uid} — so ~2-3 extra reads. Member-doc admin writes do
//   isGroupAdmin(gid) = up to 2 get()s (group doc + member doc). Reads of global public
//   collections add no get()s. Acceptable at this scale (a few dozen members/group).
service cloud.firestore {
  match /databases/{database}/documents {

    // ---- generic helpers ----------------------------------------------------

    function isSignedIn() {
      return request.auth != null;
    }

    function isInt0to30(v) {
      return v is int && v >= 0 && v <= 30;
    }

    // ---- group membership helpers (owner-derived) ---------------------------

    function groupData(gid) {
      return get(/databases/$(database)/documents/groups/$(gid)).data;
    }

    // The group owner is implicit (no member doc). One get() on the group doc.
    function isOwner(gid) {
      return isSignedIn()
        && exists(/databases/$(database)/documents/groups/$(gid))
        && groupData(gid).ownerUid == request.auth.uid;
    }

    function memberDocExists(gid) {
      return exists(/databases/$(database)/documents/groups/$(gid)/members/$(request.auth.uid));
    }

    function memberDocData(gid) {
      return get(/databases/$(database)/documents/groups/$(gid)/members/$(request.auth.uid)).data;
    }

    // Owner OR an approved member doc. Up to 2 get()s (group doc, then member doc).
    function isGroupMember(gid) {
      return isOwner(gid)
        || (isSignedIn() && memberDocExists(gid) && memberDocData(gid).status == 'approved');
    }

    // Owner OR an approved member doc with role == 'admin'.
    function isGroupAdmin(gid) {
      return isOwner(gid)
        || (
          isSignedIn()
          && memberDocExists(gid)
          && memberDocData(gid).status == 'approved'
          && memberDocData(gid).role == 'admin'
        );
    }

    // ---- superadmin (app-level god-view; ticket 014) ------------------------
    // App-level superadmin = users/{uid}.isAdmin == true. This flag is settable ONLY
    // via the admin SDK (the `users` rules forbid any client setting/changing it), so
    // no user can self-promote. It is SEPARATE from per-group admin (isGroupAdmin).
    //
    // Used only as a FINAL OR on READ rules for members / leaderboard / predictions, so
    // normal members/owners short-circuit before this helper runs and never pay its cost.
    // COST: 1 get() on users/{uid} (plus the implicit exists()). Evaluated last, only
    // when the caller is NOT already an owner/member, so member/owner reads add no extra
    // read. Read-only oversight — no create/update/delete rule references this.
    function isSuperAdmin() {
      return isSignedIn()
        && exists(/databases/$(database)/documents/users/$(request.auth.uid))
        && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.isAdmin == true;
    }

    // ---- global, read-only collections (admin SDK writes only) --------------

    match /matches/{matchId} {
      allow read: if isSignedIn();
      allow write: if false;
    }

    match /standings/{groupId} {
      allow read: if isSignedIn();
      allow write: if false;
    }

    match /config/{docId} {
      allow read: if isSignedIn();
      allow write: if false;
    }

    // ---- users (global profiles) --------------------------------------------
    // Owner reads/creates/updates their own profile. `isAdmin` may never be set or
    // changed by a client. (Note: app-level admin is deprecated by ticket 012 — admin
    // is now per-group — but the field is still guarded against tampering.)

    match /users/{uid} {
      allow read: if isSignedIn() && request.auth.uid == uid;

      allow create: if isSignedIn()
        && request.auth.uid == uid
        && request.resource.data.uid == uid
        && (!('isAdmin' in request.resource.data.keys()) || request.resource.data.isAdmin == false);

      allow update: if isSignedIn()
        && request.auth.uid == uid
        && request.resource.data.uid == uid
        && (
          !('isAdmin' in request.resource.data.keys())
          || request.resource.data.isAdmin == resource.data.isAdmin
        );

      allow delete: if false;
    }

    // ---- serverTime ---------------------------------------------------------
    // Throwaway per-user doc used by useServerTime to measure the client/server clock
    // offset. Owner-only; carries no sensitive data.

    match /serverTime/{uid} {
      allow read, write: if isSignedIn() && request.auth.uid == uid;
    }

    // ---- members collection-group read --------------------------------------
    // Authorizes `collectionGroup('members').where('uid','==', myUid)` (useMyGroups:
    // "the groups I've joined"). Collection-group queries are authorized by a recursive
    // match analyzed against the query's FIELD filter — a nested per-group match + a
    // doc-id rule do NOT cover them. Read-only here, scoped to the caller's own member
    // docs (`resource.data.uid == request.auth.uid`); writes stay governed by the nested
    // groups/{gid}/members rule. No security widening (you can already read your own doc).
    match /{path=**}/members/{memberUid} {
      allow read: if isSignedIn() && resource.data.uid == request.auth.uid;
    }

    // ---- groups -------------------------------------------------------------
    // Open app access: any signed-in user may read group metadata (needed for the join
    // page) and create a group they own. Group metadata isn't sensitive (knowing a gid
    // only lets you *request* to join). Owner-only update/delete.

    match /groups/{gid} {
      allow read: if isSignedIn();

      // Create: signed-in user creates a group with themselves as owner (single write).
      allow create: if isSignedIn()
        && request.resource.data.ownerUid == request.auth.uid;

      allow update, delete: if isOwner(gid);

      // ---- groups/{gid}/members ---------------------------------------------
      // Joiners only (the owner is implicit via groups/{gid}.ownerUid).
      //   - create: signed-in user self-requests their OWN doc as role 'member',
      //     status 'pending', no decision stamped. They may NOT self-approve nor
      //     grant themselves 'admin'.
      //   - update: (a) owner re-request after rejection (rejected -> pending, own doc,
      //     no decision stamped); or (b) a GROUP ADMIN deciding (sets status, stamps
      //     decidedBy == auth.uid and decidedAt != null, may set role). A non-admin can
      //     NEVER reach 'approved' or 'admin'.
      //   - read: own doc OR a group member (so group admins / members can see the roster).
      //   - delete: group admin only.

      match /members/{uid} {
        // Single-doc reads: own doc (by id, incl. a non-existent one — GroupProvider) or
        // a group member/admin reading the roster. The collectionGroup(members) query in
        // useMyGroups is authorized separately by the recursive-wildcard rule below.
        allow read: if (isSignedIn()
          && (request.auth.uid == uid || isGroupMember(gid)))
          || isSuperAdmin();

        // Self-request to join: own doc, uid matches, role 'member', pending, no decision.
        allow create: if isSignedIn()
          && request.auth.uid == uid
          && request.resource.data.uid == uid
          && request.resource.data.role == 'member'
          && request.resource.data.status == 'pending'
          && (
            !('decidedBy' in request.resource.data.keys())
            || request.resource.data.decidedBy == null
          )
          && (
            !('decidedAt' in request.resource.data.keys())
            || request.resource.data.decidedAt == null
          );

        allow update: if isSignedIn() && (
          // (a) owner re-requesting after a rejection: rejected -> pending only.
          (
            request.auth.uid == uid
            && resource.data.status == 'rejected'
            && request.resource.data.status == 'pending'
            && request.resource.data.uid == uid
            && (
              !('decidedBy' in request.resource.data.keys())
              || request.resource.data.decidedBy == null
            )
            && (
              !('decidedAt' in request.resource.data.keys())
              || request.resource.data.decidedAt == null
            )
          )
          // (b) a group admin deciding: stamps themselves as the decider.
          || (
            isGroupAdmin(gid)
            && request.resource.data.uid == resource.data.uid
            && request.resource.data.decidedBy == request.auth.uid
            && request.resource.data.decidedAt != null
          )
        );

        allow delete: if isGroupAdmin(gid);
      }

      // ---- groups/{gid}/predictions -----------------------------------------
      // Doc id is `{uid}_{matchId}`. Owner-only read/write. Kickoff-locked against the
      // GLOBAL matches/{matchId} doc. No points/breakdown tampering. Group members only.

      match /predictions/{predId} {
        // Reveal-at-kickoff (ticket 013): a group member reads their OWN prediction
        // anytime, or ANOTHER member's prediction only once that match has kicked off
        // (server time >= the GLOBAL matches/{matchId}.kickoff). Pre-kickoff, others'
        // predictions stay hidden so no one can copy. Cost: reading another member's
        // prediction adds 1 exists()+1 get() on the global match doc (matchHasKickedOff)
        // on top of isGroupMember(gid)'s lookups — acceptable at group scale.
        allow read: if (isSignedIn()
          && isGroupMember(gid)
          && (
            resource.data.uid == request.auth.uid
            || matchHasKickedOff(resource.data.matchId)
          ))
          || isSuperAdmin();

        allow create: if isGroupMember(gid)
          && request.auth.uid == request.resource.data.uid
          && predId == request.auth.uid + '_' + request.resource.data.matchId
          && predictionShapeValid()
          && beforeKickoff(request.resource.data.matchId);

        allow update: if isGroupMember(gid)
          && request.auth.uid == request.resource.data.uid
          && predId == request.auth.uid + '_' + request.resource.data.matchId
          && request.resource.data.matchId == resource.data.matchId
          && predictionShapeValid()
          && beforeKickoff(request.resource.data.matchId);

        allow delete: if false;
      }

      // ---- groups/{gid}/leaderboard -----------------------------------------
      // Per-group aggregate. Group members read; admin SDK is the only writer.

      match /leaderboard/{uid} {
        allow read: if isGroupMember(gid) || isSuperAdmin();
        allow write: if false;
      }
    }

    // ---- prediction validation helpers (global; reference GLOBAL matches) ---

    function predictionShapeValid() {
      return request.resource.data.uid is string
        && request.resource.data.matchId is string
        && isInt0to30(request.resource.data.homeGoals)
        && isInt0to30(request.resource.data.awayGoals)
        // clients may never write graded fields.
        && !('points' in request.resource.data.keys())
        && !('breakdown' in request.resource.data.keys());
    }

    function matchKickoff(matchId) {
      return get(/databases/$(database)/documents/matches/$(matchId)).data.kickoff;
    }

    // True while the referenced GLOBAL match exists and has not kicked off (server time).
    function beforeKickoff(matchId) {
      return exists(/databases/$(database)/documents/matches/$(matchId))
        && request.time < matchKickoff(matchId);
    }

    // True once the referenced GLOBAL match exists and HAS kicked off (server time).
    // Backs the reveal-at-kickoff read on group predictions (ticket 013). 1 exists()
    // + 1 get() on the global match doc.
    function matchHasKickedOff(matchId) {
      return exists(/databases/$(database)/documents/matches/$(matchId))
        && request.time >= matchKickoff(matchId);
    }
  }
}
